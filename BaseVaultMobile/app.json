{
  "expo": {
    "name": "BaseVault",
    "slug": "basevault",
    "version": "1.0.0",
    "scheme": "basevault",
    "android": {
      "package": "com.basevault.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "basevaultmarket.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    }
  }
}
